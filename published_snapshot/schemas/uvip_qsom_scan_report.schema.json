{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "UVIP QSO Mesh Scan Report",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schema": {"type": "string", "const": "uvip_qsom_scan_report.v1"},
    "scanned_at": {"type": "string"},
    "source_path": {"type": "string"},
    "source_kind": {"type": "string"},
    "valid": {"type": "boolean"},
    "payload_hash": {"type": "string"},
    "computed_payload_hash": {"type": "string"},
    "public_lookup_url": {"type": "string"},
    "mesh_uri": {"type": "string"},
    "errors": {
      "type": "array",
      "items": {"type": "string"}
    },
    "payload_summary": {"type": "object"},
    "scanner_boundary": {"type": "string"}
  },
  "required": [
    "schema",
    "scanned_at",
    "source_path",
    "source_kind",
    "valid",
    "payload_hash",
    "computed_payload_hash",
    "public_lookup_url",
    "mesh_uri",
    "errors",
    "payload_summary",
    "scanner_boundary"
  ]
}
