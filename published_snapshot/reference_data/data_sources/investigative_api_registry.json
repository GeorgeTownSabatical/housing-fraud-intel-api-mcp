      "category": "corporate_ownership",
      "docs_url": "https://api.opencorporates.com/documentation/API-Reference",
      "signup_url": "https://api.opencorporates.com/account/sign_up",
      "auth": {"type": "api_token_query", "env_vars": ["OPENCORPORATES_API_TOKEN"]},
      "verification": {
        "url": "https://api.opencorporates.com/v0.4/companies/search",
        "query": {"q": "property", "per_page": "1", "api_token": "{OPENCORPORATES_API_TOKEN}"}
      }
    },
    {
      "id": "california_business_search",
      "name": "California Business Search",
