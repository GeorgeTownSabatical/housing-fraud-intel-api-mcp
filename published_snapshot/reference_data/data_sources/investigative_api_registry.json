      "auth": {"type": "none", "env_vars": []}
    },
    {
      "id": "arcgis_rest",
      "name": "ArcGIS REST Services",
      "category": "gis",
      "docs_url": "https://developers.arcgis.com/rest/services-reference/enterprise/get-started-with-the-services-directory/",
      "signup_url": "https://developers.arcgis.com/rest/services-reference/",
      "auth": {"type": "mixed", "env_vars": ["ARCGIS_TOKEN"]},
      "notes": "Many county FeatureServer endpoints are public; some enterprise services require a token."
    },
    {
      "id": "courtlistener",
      "name": "CourtListener API",
      "category": "court_legal",
      "docs_url": "https://www.courtlistener.com/api/rest-info/",
      "signup_url": "https://www.courtlistener.com/sign-in/",
      "auth": {"type": "token_header", "env_vars": ["COURTLISTENER_API_TOKEN"]},
      "verification": {
        "url": "https://www.courtlistener.com/api/rest/v4/search/",
        "query": {"q": "quiet title", "page_size": "1"},
        "headers": {"Authorization": "Token {COURTLISTENER_API_TOKEN}"}
      }
    },
    {
      "id": "pacer",
      "name": "PACER Case Locator",
      "category": "court_legal",
      "docs_url": "https://pacer.uscourts.gov/",
      "signup_url": "https://pacer.uscourts.gov/register-account",
      "auth": {"type": "portal_account", "env_vars": ["PACER_USERNAME", "PACER_PASSWORD", "PACER_CLIENT_CODE"]}
    },
    {
      "id": "recap",
      "name": "RECAP Archive",
      "category": "court_legal",
      "docs_url": "https://free.law/recap/",
      "signup_url": "https://free.law/recap/",
      "auth": {"type": "none", "env_vars": []}
    },
    {
      "id": "opencorporates",
