    },
    {
      "id": "fbi_crime_data",
      "name": "FBI Crime Data API",
      "category": "crime_incident",
      "docs_url": "https://crime-data-explorer.fr.cloud.gov/pages/docApi",
      "signup_url": "https://crime-data-explorer.fr.cloud.gov/pages/docApi",
      "auth": {"type": "api_key", "env_vars": ["FBI_CRIME_DATA_API_KEY"]},
      "notes": "The public API docs and current key policy should be re-verified before production rollout."
    },
    {
      "id": "data_gov_crime",
      "name": "Data.gov Crime Datasets",
      "category": "crime_incident",
      "docs_url": "https://catalog.data.gov/dataset?tags=crime",
      "signup_url": "https://catalog.data.gov/dataset?tags=crime",
      "auth": {"type": "mixed", "env_vars": ["DATA_GOV_API_KEY"]},
      "notes": "Most catalog reads are public; some CKAN or downstream services support or prefer an API key."
