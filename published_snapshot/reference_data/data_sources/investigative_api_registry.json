{
  "providers": [
    {
      "id": "census_acs",
      "name": "U.S. Census Bureau ACS API",
      "category": "property_geography",
      "docs_url": "https://www.census.gov/data/developers/data-sets/acs-5year.html",
      "signup_url": "https://api.census.gov/data/key_signup.html",
      "auth": {"type": "api_key_optional", "env_vars": ["CENSUS_API_KEY"]},
      "verification": {
        "url": "https://api.census.gov/data/2023/acs/acs5",
        "query": {"get": "NAME", "for": "us:1", "key": "{CENSUS_API_KEY}"}
      }
    },
    {
      "id": "census_geocoder",
      "name": "U.S. Census Geocoder",
      "category": "property_geography",
      "docs_url": "https://geocoding.geo.census.gov/geocoder/Geocoding_Services_API.html",
      "signup_url": "https://geocoding.geo.census.gov/",
      "auth": {"type": "none", "env_vars": []},
      "verification": {
        "url": "https://geocoding.geo.census.gov/geocoder/locations/onelineaddress",
        "query": {
          "address": "4600 Silver Hill Rd, Washington, DC 20233",
          "benchmark": "Public_AR_Current",
          "format": "json"
        }
      }
    },
    {
      "id": "usgs_national_map",
      "name": "USGS National Map / APIs",
      "category": "property_geography",
      "docs_url": "https://www.usgs.gov/products/data-and-tools/apis",
      "signup_url": "https://www.usgs.gov/products/data-and-tools/apis",
      "auth": {"type": "none", "env_vars": []},
      "verification": {
        "url": "https://api.waterdata.usgs.gov/ogcapi/v0/collections",
        "query": {}
      }
    },
    {
      "id": "noaa_climate",
      "name": "NOAA Climate Data Online",
      "category": "property_geography",
      "docs_url": "https://www.ncei.noaa.gov/cdo-web/webservices/v2",
      "signup_url": "https://www.ncei.noaa.gov/cdo-web/token",
      "auth": {"type": "token_header", "env_vars": ["NOAA_CDO_TOKEN"]},
      "verification": {
        "url": "https://www.ncei.noaa.gov/cdo-web/api/v2/datasets",
        "query": {"limit": "1"},
        "headers": {"token": "{NOAA_CDO_TOKEN}"}
      }
    },
    {
      "id": "regrid",
      "name": "Regrid API",
      "category": "property_parcel",
      "docs_url": "https://regrid.com/api",
      "signup_url": "https://app.regrid.com/register",
      "auth": {"type": "api_key_header", "env_vars": ["REGRID_API_TOKEN"]},
      "verification": {
        "url": "https://app.regrid.com/api/v1/parcels/000000000000",
        "headers": {"X-API-KEY": "{REGRID_API_TOKEN}"}
      }
    },
    {
      "id": "la_county_open_data",
      "name": "Los Angeles County Open Data",
      "category": "property_parcel",
      "docs_url": "https://data.lacounty.gov/",
      "signup_url": "https://data.lacounty.gov/",
      "auth": {"type": "none", "env_vars": []}
    },
    {
      "id": "orange_county_open_data",
      "name": "Orange County California Open Data",
      "category": "property_parcel",
      "docs_url": "https://ocgov.com/gov/open-data",
      "signup_url": "https://ocgov.com/gov/open-data",
      "auth": {"type": "none", "env_vars": []}
    },
    {
      "id": "cook_county_open_data",
      "name": "Cook County Open Data",
      "category": "property_parcel",
